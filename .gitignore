# =============================================================================
# .gitignore for np-profiling
# =============================================================================

# --- Large data files (too big for GitHub, not included in repo) ---
data/db/
data/output/*.Rds
data/output/*.Rdata
data/output/*.RData
data/output/*.tsv
data/output/*.csv
data/input/

# --- Trained model outputs ---
results/*.Rds
results/*.Rdata
results/*.RData

# --- DrugBank database snapshot (required input — tracked in repo) ---
# drugbank/ is intentionally tracked; db_all.Rds is 67 MB (under GitHub's 100 MB limit)

# --- R session artifacts ---
.Rhistory
.RData
.Rproj.user/
*.Rproj

# --- OS artifacts ---
.DS_Store
Thumbs.db
desktop.ini
