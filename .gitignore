# =============================================================================
# .gitignore for np-profiling
# =============================================================================

# Always track .gitkeep placeholder files (used to preserve empty directories)
!**/.gitkeep

# --- Large data files (too big for GitHub; directories kept via .gitkeep) ---
data/db/*
!data/db/.gitkeep
data/output/*.Rds
data/output/*.Rdata
data/output/*.RData
data/output/*.tsv
data/output/*.csv
data/input/training/*
!data/input/training/.gitkeep
data/input/*
!data/input/.gitkeep

# --- Trained model outputs (tracked via Git LFS) ---
# results/ files are now stored in LFS — see .gitattributes

# --- DrugBank database snapshot (required input — tracked in repo) ---
# drugbank/ is intentionally tracked; db_all.Rds is 67 MB (under GitHub's 100 MB limit)

# --- R session artifacts ---
.Rhistory
.RData
.Rproj.user/
*.Rproj

# --- OS artifacts ---
.DS_Store
Thumbs.db
desktop.ini
